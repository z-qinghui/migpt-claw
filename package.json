{
  "version": "1.0.0",
  "name": "@z-qinghui/migpt-claw",
  "publishConfig": {
    "access": "public"
  },
  "description": "小米小爱音箱 OpenClaw Channel 插件",
  "keywords": [
    "openclaw",
    "xiaomi",
    "mi-gpt",
    "mico",
    "channel"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "setup-entry.ts",
    "skills",
    "openclaw.plugin.json",
    "tsconfig.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "migpt",
      "label": "MiGPT",
      "selectionLabel": "小米音箱 (MiGPT)",
      "blurb": "小米小爱音箱语音对话，让小爱音箱成为你的龙虾语音助手",
      "docsPath": "/channels/migpt",
      "docsLabel": "MiGPT 文档",
      "order": 60,
      "aliases": ["xiaomi", "mico"],
      "markdownCapable": false,
      "exposure": {
        "configured": true,
        "setup": true,
        "docs": true
      }
    },
    "install": {
      "clawhubSpec": "@z-qinghui/migpt-claw",
      "npmSpec": "@z-qinghui/migpt-claw",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=0.1.0"
    },
    "startup": {
      "deferConfiguredChannelFullLoadUntilAfterListen": true
    }
  },
  "compat": {
    "pluginApi": ">=0.1.0",
    "minHostVersion": ">=0.1.0"
  },
  "build": {
    "openclawVersion": "0.1.0",
    "pluginSdkVersion": "0.1.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "node-fetch": "^3.3.2",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/node": "^22.14.0",
    "@types/pako": "^2.0.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "license": "MIT",
  "author": {
    "name": "z-qinghui",
    "url": "https://github.com/z-qinghui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/z-qinghui/migpt-claw.git"
  }
}
